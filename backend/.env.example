# Backend Development Environment Variables

# Server Port
PORT=3000

# Security (Chrome Extension ID for CORS)
EXTENSION_URL=chrome-extension://my_chrome_ext_id_here

# Redis (Upstash)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_UPSTASH_ENDPOINT.upstash.io:6379

# Supabase (Admin service role is needed on backend)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
